{
  "manifest_version": 3,
  "name": "BetterYahoo",
  "version": "1.1",
  "description": "Enhance your Yahoo Finance experience with organized folders, sticking toolbar, and transcript export.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://finance.yahoo.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "48": "icons/finance48.png",
    "128": "icons/finance128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open BetterYahoo Sidepanel"
  },
  "content_scripts": [
    {
      "matches": [
        "https://finance.yahoo.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}