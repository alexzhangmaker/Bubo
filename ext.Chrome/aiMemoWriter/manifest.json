{
    "manifest_version": 3,
    "name": "aiMemoWriter",
    "version": "1.0",
    "description": "Adds a sticky toolbar to chat.deepseek.com to save AI content as Markdown.",
    "permissions": [
        "clipboardRead",
        "sidePanel",
        "storage"
    ],
    "action": {
        "default_title": "AIHelper Config"
    },
    "side_panel": {
        "default_path": "sidepanel/sidepanel.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chat.deepseek.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "icons": {
        "48": "icon48.png",
        "128": "icon128.png"
    }
}