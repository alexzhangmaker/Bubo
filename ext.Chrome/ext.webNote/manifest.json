{
    "manifest_version": 3,
    "name": "WebNote & Reader Mode",
    "version": "1.0",
    "description": "Customizable reader mode with sidebar notes.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "contextMenus",
        "sidePanel",
        "identity"
    ],
    "oauth2": {
        "client_id": "724993324937-9i65tg3thqao2rauodbdf708m80sanq6.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/userinfo.email",
            "https://www.googleapis.com/auth/userinfo.profile",
            "https://www.googleapis.com/auth/firebase.database",
            "https://www.googleapis.com/auth/devstorage.read_write",
            "https://www.googleapis.com/auth/cloud-platform",
            "https://www.googleapis.com/auth/drive.file"
        ]
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "WebNote"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "lib/tiptap.js",
                "content.js"
            ],
            "css": [
                "lib/tiptap.css",
                "styles.css"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}