{
    "manifest_version": 3,
    "name": "BetterYouTube",
    "version": "1.0",
    "description": "Enhance YouTube experience with sidepanel management, keyword blocking, and socket communication.",
    "permissions": [
        "sidePanel",
        "storage",
        "unlimitedStorage",
        "offscreen",
        "tabs",
        "scripting",
        "identity",
        "history"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel/sidepanel.html"
    },
    "action": {
        "default_title": "Open BetterYouTube Sidepanel",
        "default_icon": {
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/content.css"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*"
            ],
            "matches": [
                "https://www.youtube.com/*"
            ]
        }
    ]
}