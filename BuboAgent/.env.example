# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Firebase & Google Cloud (Service Account)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# Server
PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Note: Google Drive & Sheets now use the same Service Account as Firebase.
# IMPORTANT: You must SHARE your Google Drive folder or Google Sheet with the 
# FIREBASE_CLIENT_EMAIL address (e.g., xxx@thoughts-cc393.iam.gserviceaccount.com)
# so the Agent has permission to access it.
